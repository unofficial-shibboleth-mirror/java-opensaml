<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%-5level %logger{0} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>
    
    <logger name="org.opensaml.xmlsec.derivation.impl.DHLegacyKDF" level="TRACE" />
    
    <logger name="org.apache.xml.security.encryption.XMLCipher" level="TRACE" />

    <logger name="org.apache.xml.security.encryption.XMLCipherUtil" level="TRACE" />
    
    <logger name="org.opensaml.core.testing" level="TRACE" />
    
    <logger name="org.opensaml.xmlsec.encryption.support" level="TRACE" />
    
    <logger name="org.opensaml.xmlsec.keyinfo" level="WARN" />
    
    <logger name="org.opensaml.xmlsec.impl" level="TRACE" />
    
    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>
    
</configuration>
